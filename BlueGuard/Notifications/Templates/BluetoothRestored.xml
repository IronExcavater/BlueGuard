<toast launch="app" activationType="foreground">
  <visual>
    <binding template="ToastGeneric">
      <text>ms-resource:AppName</text>
      <text>ms-resource:NotificationRestoredBody</text>
      <image placement="appLogoOverride"
             src="ms-appx:///Assets/Square44x44Logo.scale-200.png"
             hint-crop="circle"/>
    </binding>
  </visual>
  <actions>
    <action content="ms-resource:NotificationRestoredActionTurnOff"
            arguments="turnoff"
            activationType="foreground"/>
  </actions>
</toast>
